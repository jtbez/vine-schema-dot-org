{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "declaration": true,
        "rootDir": "src"
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "__tests__/**",
        "node_modules/**",
        "dist/**",
        "data/**"
    ]
}
